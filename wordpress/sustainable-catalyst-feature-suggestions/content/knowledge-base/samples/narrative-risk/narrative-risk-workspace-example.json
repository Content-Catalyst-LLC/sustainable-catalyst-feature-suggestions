  "classification": "synthetic-demo",
  "features": [
    {
      "feature_id": "NARRATIVE-RISK-001",
      "feature": "Case Workspace",
      "sample_action": "create NR-RETROFIT-001",
      "expected_result": "a persistent narrative-risk case"
    },
    {
      "feature_id": "NARRATIVE-RISK-002",
      "feature": "Artifact Intake",
      "sample_action": "register a public retrofit announcement with URL, date, version, and custody",
