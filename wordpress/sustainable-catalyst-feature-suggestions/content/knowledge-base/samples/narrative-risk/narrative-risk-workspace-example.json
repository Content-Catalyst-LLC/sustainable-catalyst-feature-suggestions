    },
    {
      "feature_id": "NARRATIVE-RISK-003",
      "feature": "Claim Decomposition",
      "sample_action": "separate cost, emissions, comfort, and timeline claims",
      "expected_result": "atomic claim records"
    },
    {
      "feature_id": "NARRATIVE-RISK-004",
      "feature": "Narrative Mapping",
      "sample_action": "map frames, causal stories, heroes, harms, omissions, and implied action",
      "expected_result": "a structured narrative map"
    },
    {
      "feature_id": "NARRATIVE-RISK-005",
      "feature": "Actor and Audience Context",
      "sample_action": "record speaker, institution, intended audience, affected groups, and power context",
      "expected_result": "actor and audience records"
    },
    {
      "feature_id": "NARRATIVE-RISK-006",
      "feature": "Source Ledger",
      "sample_action": "preserve origin, retrieval, version, and custody",
      "expected_result": "a source ledger"
    },
    {
      "feature_id": "NARRATIVE-RISK-007",
      "feature": "Evidence Ledger",
      "sample_action": "link each claim to supporting, challenging, and contextual evidence",
