    },
    {
      "feature_id": "NARRATIVE-RISK-009",
      "feature": "Scoring Method",
      "sample_action": "apply the canonical transparent scoring rubric",
      "expected_result": "a method-versioned score and rationale"
    },
    {
      "feature_id": "NARRATIVE-RISK-010",
      "feature": "Uncertainty",
      "sample_action": "record missing evidence, ambiguity, confidence, and reviewer disagreement",
      "expected_result": "an uncertainty record"
    },
    {
      "feature_id": "NARRATIVE-RISK-011",
      "feature": "Counterevidence",
