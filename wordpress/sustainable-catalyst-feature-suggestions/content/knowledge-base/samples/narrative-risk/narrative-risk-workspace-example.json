      "expected_result": "a balanced evidence view"
    },
    {
      "feature_id": "NARRATIVE-RISK-012",
      "feature": "Comparison",
      "sample_action": "compare draft and final announcements or two cases",
      "expected_result": "a change and risk comparison"
    },
    {
      "feature_id": "NARRATIVE-RISK-013",
      "feature": "Review Workflow",
      "sample_action": "request factual, harm, and governance review",
      "expected_result": "a review trail"
    },
    {
      "feature_id": "NARRATIVE-RISK-014",
      "feature": "Approval",
      "sample_action": "require authorized approval for an official assessment",
      "expected_result": "an approval record and rationale"
    },
    {
      "feature_id": "NARRATIVE-RISK-015",
      "feature": "Governance Log",
      "sample_action": "record method changes, overrides, conflicts, and score revisions",
      "expected_result": "an auditable event log"
    },
    {
      "feature_id": "NARRATIVE-RISK-016",
      "feature": "Exports and Handoffs",
      "sample_action": "send an approved risk summary to Decision Studio",
      "expected_result": "a portable privacy-aware artifact"
