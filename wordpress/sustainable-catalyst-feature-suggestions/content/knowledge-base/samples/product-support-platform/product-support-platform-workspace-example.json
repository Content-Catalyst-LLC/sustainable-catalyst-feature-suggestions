    {
      "feature_id": "PRODUCT-SUPPORT-PLATFORM-020",
      "feature": "Cross-Product Journeys",
      "sample_action": "guide users from data to analysis to decision",
      "expected_result": "a connected support journey"
    },
    {
      "feature_id": "PRODUCT-SUPPORT-PLATFORM-021",
      "feature": "Connected Operations",
      "sample_action": "review dossiers, blockers, readiness, actions, and snapshots",
      "expected_result": "an operations report"
    },
    {
      "feature_id": "PRODUCT-SUPPORT-PLATFORM-022",
      "feature": "Private Support Handoff",
      "sample_action": "send consented product/version/problem context to Contact and Engagement",
