{
  "schema": "sckb-feature-demo/1.0",
  "workspace_id": "PRODUCT-SUPPORT-PLATFORM-RETROFIT-001",
  "product": "Product Support and Feedback Platform",
  "product_slug": "product-support-platform",
  "product_version": "5.1.0",
  "classification": "synthetic-demo",
  "features": [
    {
      "feature_id": "PRODUCT-SUPPORT-PLATFORM-001",
      "feature": "Product Taxonomy",
      "sample_action": "assign Product, Version, Component, Issue Type, and Release",
      "expected_result": "consistent routing context"
    },
    {
      "feature_id": "PRODUCT-SUPPORT-PLATFORM-002",
      "feature": "Support Articles",
      "sample_action": "create detailed guides as sc_support_article drafts",
      "expected_result": "searchable product documentation"
    },
    {
      "feature_id": "PRODUCT-SUPPORT-PLATFORM-003",
      "feature": "Documentation Collections",
      "sample_action": "group six guides into a hierarchical product collection",
      "expected_result": "a browsable documentation set"
    },
    {
      "feature_id": "PRODUCT-SUPPORT-PLATFORM-004",
      "feature": "Article Types",
      "sample_action": "classify Getting Started, How-to, Troubleshooting, and Technical Reference",
      "expected_result": "filtered content"
    },
    {
      "feature_id": "PRODUCT-SUPPORT-PLATFORM-005",
      "feature": "Guided Resolution",
      "sample_action": "match an endpoint error to articles, issues, releases, and next steps",
      "expected_result": "a product-aware route"
    },
    {
      "feature_id": "PRODUCT-SUPPORT-PLATFORM-006",
      "feature": "Known Issues",
      "sample_action": "publish symptom, severity, state, workaround, and resolution",
