    },
    {
      "feature_id": "PRODUCT-SUPPORT-PLATFORM-007",
      "feature": "Release Intelligence",
      "sample_action": "connect current, planned, maintenance, superseded, and retired releases",
      "expected_result": "a release record with related guidance"
    },
    {
      "feature_id": "PRODUCT-SUPPORT-PLATFORM-008",
      "feature": "Public Ideas",
      "sample_action": "publish a moderated feature proposal",
      "expected_result": "a public idea and official status"
    },
    {
      "feature_id": "PRODUCT-SUPPORT-PLATFORM-009",
      "feature": "Voting",
      "sample_action": "record advisory support without automatic prioritization",
      "expected_result": "a bounded support signal"
    },
    {
      "feature_id": "PRODUCT-SUPPORT-PLATFORM-010",
      "feature": "Forms and Surveys",
      "sample_action": "run a documentation-usefulness survey",
      "expected_result": "private responses and reviewed analysis"
    },
    {
      "feature_id": "PRODUCT-SUPPORT-PLATFORM-011",
      "feature": "Article Feedback",
      "sample_action": "collect helpful/not-helpful and step-specific comments",
      "expected_result": "a quality signal"
    },
    {
      "feature_id": "PRODUCT-SUPPORT-PLATFORM-012",
      "feature": "Failed Search Intelligence",
      "sample_action": "track searches such as restore workspace",
      "expected_result": "a documentation-gap signal"
    },
    {
      "feature_id": "PRODUCT-SUPPORT-PLATFORM-013",
      "feature": "Documentation Gaps",
      "sample_action": "combine search, issue, support, and feedback evidence",
      "expected_result": "a ranked editorial opportunity"
    },
    {
      "feature_id": "PRODUCT-SUPPORT-PLATFORM-014",
      "feature": "Product Onboarding",
      "sample_action": "register product owners, routes, versions, components, and readiness",
      "expected_result": "a support profile"
    },
    {
      "feature_id": "PRODUCT-SUPPORT-PLATFORM-015",
      "feature": "Content Import and Export",
      "sample_action": "import this JSON corpus as drafts and export governed records",
      "expected_result": "an integrity-tracked batch"
    },
    {
      "feature_id": "PRODUCT-SUPPORT-PLATFORM-016",
      "feature": "Editorial Governance",
      "sample_action": "assign standards, lifecycle, reviewers, freshness, and approval",
      "expected_result": "a human publication trail"
    },
    {
      "feature_id": "PRODUCT-SUPPORT-PLATFORM-017",
      "feature": "Repository Sync",
      "sample_action": "compare repository documentation with Knowledge Base coverage",
      "expected_result": "a synchronization finding"
    },
    {
      "feature_id": "PRODUCT-SUPPORT-PLATFORM-018",
      "feature": "Reliability Analytics",
      "sample_action": "combine issue, incident, support-demand, and product evidence",
      "expected_result": "an advisory reliability dossier"
