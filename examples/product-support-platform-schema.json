{
  "schema": "scfs-product-support-platform/1.0",
  "version": "4.0.0",
  "platform": "Sustainable Catalyst Product Support and Feedback Platform",
  "public_modules": [
    "guided_resolution",
    "support_knowledge_base",
    "known_issues",
    "release_intelligence",
    "feature_suggestions",
    "public_ideas",
    "advisory_voting",
    "forms_and_surveys"
  ],
  "private_integrations": ["contact_and_engagement"],
  "governance": {
    "voting_is_advisory": true,
    "surveys_do_not_auto_prioritize": true,
    "human_review_required": true,
    "automatic_case_creation": false
  }
