{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sustainablecatalyst.com/schemas/scfs-installed-plugin-discovery-v1.schema.json",
  "title": "Sustainable Catalyst Installed Plugin Discovery",
  "type": "object",
  "required": [
    "schema",
    "version",
    "scanned_at",
    "installed_plugin_count",
    "matches",
    "pending"
  ],
  "additionalProperties": false,
  "properties": {
    "schema": {
      "const": "scfs-installed-plugin-discovery/1.0"
    },
    "version": {
      "const": "7.8.0"
    },
    "scanned_at": {
      "type": "string"
    },
    "reason": {
      "type": "string"
    },
    "installed_plugin_count": {
      "type": "integer",
      "minimum": 0
    },
    "matches": {
      "type": "array",
      "maxItems": 250,
      "items": {
        "$ref": "#/$defs/match"
      }
    },
    "pending": {
      "type": "array",
      "maxItems": 250,
      "items": {
        "$ref": "#/$defs/candidate"
      }
    },
    "diagnostics": {
      "type": "array",
      "maxItems": 250,
      "items": {
        "$ref": "#/$defs/diagnostic"
      }
    },
    "ignored": {
      "type": "array",
      "maxItems": 250,
      "items": {
        "$ref": "#/$defs/candidate"
      }
    },
    "manual_mappings": {
      "type": "array",
      "maxItems": 250,
      "items": {
        "$ref": "#/$defs/manual_mapping"
      }
    },
    "standard_plugin_count": {
      "type": "integer",
      "minimum": 0
    },
    "site_active_plugin_count": {
      "type": "integer",
      "minimum": 0
    },
    "network_active_plugin_count": {
      "type": "integer",
      "minimum": 0
    },
    "both_active_plugin_count": {
      "type": "integer",
      "minimum": 0
    },
    "inactive_plugin_count": {
      "type": "integer",
      "minimum": 0
    },
    "must_use_plugin_count": {
      "type": "integer",
      "minimum": 0
    },
    "dropin_count": {
      "type": "integer",
      "minimum": 0
    },
    "update_available_count": {
      "type": "integer",
      "minimum": 0
    },
    "ahead_of_release_count": {
      "type": "integer",
      "minimum": 0
    },
    "unknown_version_count": {
      "type": "integer",
      "minimum": 0
    },
    "inventory": {
      "type": "array",
      "maxItems": 10000,
      "items": {
        "$ref": "#/$defs/inventory"
      }
    }
  },
  "$defs": {
    "match": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "product_id",
        "plugin_file",
        "plugin_name",
        "version",
        "version_raw",
        "version_state",
        "active",
        "activation_scope",
        "match_strategy",
        "confidence",
        "legacy_match"
      ],
      "properties": {
        "product_id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "plugin_file": {
          "type": "string",
          "pattern": "^[^/][^\\\\]*\\.php$"
        },
        "plugin_name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string"
        },
        "text_domain": {
          "type": "string"
        },
        "active": {
          "type": "boolean"
        },
        "match_strategy": {
          "enum": [
            "administrator_mapping",
            "exact_plugin_file",
            "legacy_plugin_file",
            "sc_product_id_header",
            "sc_product_header",
            "plugin_slug",
            "legacy_plugin_slug",
            "text_domain",
            "legacy_text_domain",
            "plugin_repository_url",
            "approved_name_alias"
          ]
        },
        "confidence": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "discovered_at": {
          "type": "string"
        },
        "version_raw": {
          "type": "string"
        },
        "version_state": {
          "enum": [
            "valid",
            "development",
            "missing",
            "malformed"
          ]
        },
        "activation_scope": {
          "enum": [
            "inactive",
            "site",
            "network",
            "both"
          ]
        },
        "legacy_match": {
          "type": "boolean"
        },
        "match_signals": {
          "type": "array",
          "maxItems": 12,
          "items": {
            "type": "string"
          }
        },
        "plugin_type": {
          "enum": [
            "standard",
            "must-use",
            "drop-in"
          ]
        },
        "plugin_uri": {
          "type": "string"
        },
        "latest_version": {
          "type": "string"
        },
        "version_comparison": {
          "enum": [
            "current",
            "update_available",
            "ahead",
            "unknown"
          ]
        }
      }
    },
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "plugin_file",
        "name",
        "version",
        "version_raw",
        "version_state",
        "active",
        "activation_scope",
        "review_state"
      ],
      "properties": {
        "plugin_file": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "author": {
          "type": "string"
        },
        "text_domain": {
          "type": "string"
        },
        "active": {
          "type": "boolean"
        },
        "suggested_product_id": {
          "type": "string"
        },
        "review_state": {
          "enum": [
            "pending",
            "duplicate_match",
            "malformed_header"
          ]
        },
        "version_raw": {
          "type": "string"
        },
        "version_state": {
          "enum": [
            "valid",
            "development",
            "missing",
            "malformed"
          ]
        },
        "activation_scope": {
          "enum": [
            "inactive",
            "site",
            "network",
            "both"
          ]
        },
        "selected_plugin_file": {
          "type": "string"
        },
        "directory_slug": {
          "type": "string"
        },
        "sc_product_id": {
          "type": "string"
        },
        "sc_product": {
          "type": "string"
        },
        "sc_public_release": {
          "type": "string"
        },
        "ignored_at": {
          "type": "string"
        },
        "ignored_by": {
          "type": "string"
        },
        "suggested_confidence": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "suggestion_signals": {
          "type": "array",
          "maxItems": 12,
          "items": {
            "type": "string"
          }
        },
        "suggestions": {
          "type": "array",
          "maxItems": 5,
          "items": {
            "$ref": "#/$defs/suggestion"
          }
        },
        "plugin_type": {
          "enum": [
            "standard",
            "must-use",
            "drop-in"
          ]
        },
        "plugin_uri": {
          "type": "string"
        }
      }
    },
    "diagnostic": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "level",
        "code",
        "product_id",
        "plugin_file",
        "message"
      ],
      "properties": {
        "level": {
          "enum": [
            "error",
            "warning",
            "info"
          ]
        },
        "code": {
          "type": "string"
        },
        "product_id": {
          "type": "string"
        },
        "plugin_file": {
          "type": "string"
        },
        "message": {
          "type": "string"
        }
      }
    },
    "manual_mapping": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "plugin_file",
        "product_id",
        "mapped_at",
        "mapped_by"
      ],
      "properties": {
        "plugin_file": {
          "type": "string"
        },
        "product_id": {
          "type": "string"
        },
        "mapped_at": {
          "type": "string"
        },
        "mapped_by": {
          "type": "string"
        },
        "plugin_name": {
          "type": "string"
        },
        "plugin_slug": {
          "type": "string"
        },
        "text_domain": {
          "type": "string"
        },
        "target_before": {
          "type": "object"
        },
        "source_product_id": {
          "type": "string"
        },
        "source_before": {
          "type": "object"
        }
      }
    },
    "suggestion": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "product_id",
        "name",
        "confidence",
        "signals",
        "primary_signal"
      ],
      "properties": {
        "product_id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "confidence": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "signals": {
          "type": "array",
          "maxItems": 12,
          "items": {
            "type": "string"
          }
        },
        "primary_signal": {
          "type": "string"
        }
      }
    },
    "inventory": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "plugin_file",
        "name",
        "version",
        "version_state",
        "active",
        "activation_scope",
        "plugin_type",
        "mapping_state",
        "version_comparison"
      ],
      "properties": {
        "plugin_file": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "version_state": {
          "enum": [
            "valid",
            "development",
            "missing",
            "malformed"
          ]
        },
        "active": {
          "type": "boolean"
        },
        "activation_scope": {
          "enum": [
            "inactive",
            "site",
            "network",
            "both"
          ]
        },
        "plugin_type": {
          "enum": [
            "standard",
            "must-use",
            "drop-in"
          ]
        },
        "text_domain": {
          "type": "string"
        },
        "plugin_uri": {
          "type": "string"
        },
        "mapping_state": {
          "enum": [
            "matched",
            "review",
            "ignored",
            "unclassified"
          ]
        },
        "product_id": {
          "type": "string"
        },
        "match_strategy": {
          "type": "string"
        },
        "confidence": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "suggested_product_id": {
          "type": "string"
        },
        "suggested_confidence": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "suggestion_signals": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "latest_version": {
          "type": "string"
        },
        "version_comparison": {
          "enum": [
            "current",
            "update_available",
            "ahead",
            "unknown"
          ]
        }
      }
    }
  }
}
