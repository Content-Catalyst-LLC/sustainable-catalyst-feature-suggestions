{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sustainablecatalyst.com/schemas/scfs-help-desk-institutional-workspaces-v1.schema.json",
  "title": "Sustainable Catalyst Help Desk Institutional Workspaces",
  "type": "object",
  "required": [
    "schema",
    "version",
    "workspace",
    "governance"
  ],
  "properties": {
    "schema": {
      "const": "scfs-help-desk-institutional-workspaces/1.0"
    },
    "version": {
      "const": "6.11.0"
    },
    "workspace": {
      "type": "object",
      "required": [
        "workspace_key",
        "organization_name",
        "state",
        "private_workspace"
      ],
      "properties": {
        "workspace_key": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]{1,119}$"
        },
        "organization_name": {
          "type": "string",
          "minLength": 2,
          "maxLength": 191
        },
        "state": {
          "enum": [
            "active",
            "paused",
            "closed"
          ]
        },
        "private_workspace": {
          "const": true
        },
        "departments": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "service_policy_key": {
          "type": "string"
        },
        "retention_days": {
          "type": "integer",
          "minimum": 30
        }
      }
    },
    "members": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "external_subject_hash",
          "role"
        ],
        "properties": {
          "external_subject_hash": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "role": {
            "enum": [
              "workspace_admin",
              "support_manager",
              "requester",
              "auditor",
              "observer"
            ]
          },
          "capabilities": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "entitlements": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "entitlement_key": {
            "type": "string"
          },
          "active": {
            "type": "boolean"
          },
          "case_limit": {
            "type": "integer",
            "minimum": 0
          },
          "products": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "case_access": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "case_number",
          "explicit_grant"
        ],
        "properties": {
          "case_number": {
            "type": "string",
            "pattern": "^SC-[0-9]{4}-[0-9]{6}$"
          },
          "explicit_grant": {
            "const": true
          },
          "scope": {
            "enum": [
              "view",
              "reply",
              "manage"
            ]
          }
        }
      }
    },
    "collections": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "collection_key": {
            "type": "string"
          },
          "visibility_scope": {
            "enum": [
              "workspace",
              "department",
              "role"
            ]
          },
          "private_case_content_copied": {
            "const": false
          },
          "attachment_content_copied": {
            "const": false
          }
        }
      }
    },
    "report": {
      "type": "object",
      "properties": {
        "minimum_cohort": {
          "type": "integer",
          "minimum": 2
        },
        "suppressed": {
          "type": "boolean"
        },
        "report_sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    },
    "governance": {
      "type": "object",
      "required": [
        "identity_authority",
        "storage_authority",
        "automatic_case_sharing",
        "public_institutional_branding",
        "sponsor_influence"
      ],
      "properties": {
        "identity_authority": {
          "const": "contact-engagement"
        },
        "storage_authority": {
          "const": "contact-engagement"
        },
        "requester_identity_copied": {
          "const": false
        },
        "private_message_content_copied": {
          "const": false
        },
        "attachment_content_copied": {
          "const": false
        },
        "automatic_access_grants": {
          "const": false
        },
        "automatic_case_sharing": {
          "const": false
        },
        "automatic_entitlement_changes": {
          "const": false
        },
        "public_institutional_branding": {
          "const": false
        },
        "sponsor_influence": {
          "const": false
        },
        "human_review_required": {
          "const": true
        }
      }
    }
  },
  "additionalProperties": false
}
