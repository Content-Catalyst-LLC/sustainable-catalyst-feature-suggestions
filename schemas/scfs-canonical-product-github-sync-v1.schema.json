{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sustainablecatalyst.com/schemas/scfs-canonical-product-github-sync-v1.schema.json",
  "title": "Sustainable Catalyst Canonical Product GitHub Synchronization",
  "type": "object",
  "required": [
    "schema",
    "version",
    "product_id",
    "repository_url",
    "sync_state"
  ],
  "additionalProperties": false,
  "properties": {
    "schema": {
      "const": "scfs-canonical-product-github-sync/1.0"
    },
    "version": {
      "const": "7.7.1"
    },
    "product_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "repository_url": {
      "type": "string",
      "format": "uri"
    },
    "default_branch": {
      "type": "string"
    },
    "latest_version": {
      "type": "string"
    },
    "latest_release_url": {
      "type": "string"
    },
    "latest_commit_sha": {
      "type": "string"
    },
    "repository_updated_at": {
      "type": "string"
    },
    "last_synced_at": {
      "type": "string"
    },
    "sync_state": {
      "enum": [
        "unconfigured",
        "pending",
        "current",
        "error"
      ]
    },
    "sync_message": {
      "type": "string"
    },
    "latest_tag_name": {
      "type": "string"
    },
    "latest_tag_url": {
      "type": "string"
    },
    "version_source": {
      "enum": [
        "none",
        "github_release",
        "github_tag"
      ]
    },
    "connection_state": {
      "enum": [
        "connected",
        "semantic_tag",
        "connected_no_release",
        "authentication_required",
        "repository_unavailable",
        "rate_limited",
        "network_error",
        "request_error",
        "invalid_response"
      ]
    },
    "error_code": {
      "type": "string"
    },
    "http_status": {
      "type": "integer",
      "minimum": 0
    },
    "endpoint": {
      "type": "string"
    },
    "endpoint_url": {
      "type": "string"
    }
  }
}
