{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sustainablecatalyst.com/schemas/scfs-github-connection-settings-v1.schema.json",
  "title": "Sustainable Catalyst GitHub Connection Settings",
  "type": "object",
  "required": [
    "schema",
    "version",
    "token_source",
    "token_configured",
    "webhook_secret_source",
    "webhook_secret_configured"
  ],
  "properties": {
    "schema": {
      "const": "scfs-github-connection-settings/1.0"
    },
    "version": {
      "const": "7.5.5"
    },
    "token_source": {
      "enum": [
        "none",
        "wp_config",
        "environment",
        "wordpress"
      ]
    },
    "token_configured": {
      "type": "boolean"
    },
    "webhook_secret_source": {
      "enum": [
        "none",
        "wp_config",
        "environment",
        "wordpress"
      ]
    },
    "webhook_secret_configured": {
      "type": "boolean"
    },
    "mapped_repository_count": {
      "type": "integer",
      "minimum": 0
    },
    "last_tested_at": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
